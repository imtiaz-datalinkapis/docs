{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DataLink APIs",
  "colors": {
    "primary": "#10B981",
    "light": "#4EDEA3",
    "dark": "#006C49"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://datalinkapis.com/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://datalinkapis.com/login"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Core Concepts",
            "pages": ["credits", "rate-limits", "errors"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Core Endpoints",
            "pages": [
              "api-reference/email",
              "api-reference/ip",
              "api-reference/phone",
              "api-reference/domain"
            ]
          },
          {
            "group": "Bundle Endpoints",
            "pages": [
              "api-reference/deliverability",
              "api-reference/contact-intel",
              "api-reference/fraud-signals"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Playground",
          "href": "https://datalinkapis.com/playground",
          "icon": "bolt"
        },
        {
          "anchor": "Status",
          "href": "https://status.datalinkapis.com",
          "icon": "signal"
        },
        {
          "anchor": "Contact",
          "href": "https://datalinkapis.com/contact",
          "icon": "envelope"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/datalinkapis"
    }
  }
}
